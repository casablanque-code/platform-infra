{
  "id": "docker-host",
  "name": "Docker Host",
  "description": "Ubuntu container with Docker CE + Compose. Ready in ~2 minutes.",
  "category": "compute",
  "providers": ["incus"],
  "default_ttl_hours": 72,
  "inputs": [
    { "key": "cpu",       "label": "CPU cores", "type": "select", "options": ["1","2","4"],              "default": "2"    },
    { "key": "memory_mb", "label": "RAM (MB)",  "type": "select", "options": ["512","1024","2048","4096"],"default": "2048" },
    { "key": "disk_gb",   "label": "Disk (GB)", "type": "select", "options": ["10","20","50"],           "default": "20"   }
  ]
}
