{
  "id": "docker-host",
  "name": "Docker Host",
  "description": "Provision an Ubuntu VM prepared for Docker workloads.",
  "category": "compute",
  "providers": ["oracle", "hetzner"],
  "default_region": "eu-frankfurt",
  "default_ttl_hours": 72,
  "inputs": [
    {
      "name": "name",
      "label": "Environment name",
      "type": "string",
      "required": true
    },
    {
      "name": "region",
      "label": "Region",
      "type": "string",
      "required": true
    }
  ]
}
