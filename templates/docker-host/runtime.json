{
  "template_id": "docker-host",

  "executor": {
    "type": "opentofu",
    "module_path": "templates/docker-host/tofu"
  },

  "outputs": [
    "public_ip",
    "private_ip",
    "region",
    "server_type",
    "ssh_user",
    "ssh_port"
  ],

  "post_provision": [
    { "type": "ssh_script", "script": "bootstrap/base.sh" },
    { "type": "ssh_script", "script": "bootstrap/docker.sh" }
  ]
}
