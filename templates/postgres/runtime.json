{
  "template_id": "postgres",

  "executor": {
    "type": "opentofu",
    "module_path": "templates/postgres/tofu"
  },

  "outputs": [
    "db_host",
    "db_port",
    "db_name",
    "db_user",
    "db_password",
    "db_url",
    "region"
  ],

  "post_provision": [
    { "type": "ssh_script", "script": "bootstrap/base.sh" },
    { "type": "ssh_script", "script": "bootstrap/docker.sh" },
    { "type": "ssh_script", "script": "bootstrap/install_cfzt.sh" },
    { "type": "ssh_script", "script": "bootstrap/checkin.sh" }
  ],

  "actions": [
    { "id": "install_pgadmin", "label": "Install pgAdmin", "script": "bootstrap/install_pgadmin.sh" },
    { "id": "backup_to_r2",   "label": "Backup to R2",   "script": "bootstrap/backup_to_r2.sh" }
  ]
}
