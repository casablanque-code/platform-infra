{
  "id": "postgres",
  "name": "PostgreSQL",
  "description": "Ubuntu container with PostgreSQL pre-installed. DB credentials saved automatically.",
  "category": "database",
  "providers": ["incus"],
  "default_ttl_hours": 72,
  "inputs": [
    { "key": "cpu",        "label": "CPU cores",          "type": "select", "options": ["1","2"],       "default": "1"  },
    { "key": "memory_mb",  "label": "RAM (MB)",           "type": "select", "options": ["512","1024","2048"], "default": "1024" },
    { "key": "pg_version", "label": "PostgreSQL version", "type": "select", "options": ["14","15","16"],"default": "15" }
  ]
}
